{
  "_comment": "Example MCP configuration files. Choose one based on your setup.",
  "_note": "If Docker is not available, the client will automatically fall back to HTTP connection.",
  
  "mcpServers": {
    "ratings-api-docker": {
      "_description": "Use this if running in Docker environment",
      "command": "docker",
      "args": [
        "exec",
        "-i",
        "ratings-api-api-1",
        "python",
        "/app/run_mcp_server.py"
      ],
      "env": {
        "API_URL": "http://localhost:8000",
        "MONGODB_URL": "mongodb://admin:password@localhost:37017/?authSource=admin",
        "MONGODB_DB_NAME": "ratings_db",
        "PYTHONPATH": "/app"
      }
    },
    
    "ratings-api-local": {
      "_description": "Use this if running locally without Docker",
      "command": "python",
      "args": [
        "run_mcp_server.py"
      ],
      "env": {
        "API_URL": "http://localhost:8000",
        "MONGODB_URL": "mongodb://admin:password@localhost:37017/?authSource=admin",
        "MONGODB_DB_NAME": "ratings_db"
      }
    }
  }
}

